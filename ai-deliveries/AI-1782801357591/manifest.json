      "rules": [
        {
          "id": "high-dose-director-review",
          "name": "高剂量主任复核",
          "expression": "prescription.totalDoseGy >= 60",
          "action": "director-review-required",
          "severity": "high",
          "enabled": true
        },
        {
          "id": "low-gamma-block-treatment",
          "name": "Gamma低通过率禁止治疗",
          "expression": "dosePlan.gammaPassRate < 95",
          "action": "block-treatment-schedule",
          "severity": "critical",
          "enabled": true
        },
        {
          "id": "reset-verification-overdue-nurse-alert",
          "name": "复位验证超8小时提醒护士长",
          "expression": "workflow.currentStep.id == 'reset-verification' && workflow.currentStep.elapsedHours > 8",
