  ],
  "reportTemplates": [
    {
      "id": "treatment-prep-summary",
      "name": "治疗准备汇总",
      "audience": "放疗医生",
      "dataset": "patients",
      "fields": [
        "name",
        "diagnosis",
        "currentStepId",
        "prescription.totalDoseGy",
        "dosePlan.gammaPassRate"
      ],
      "schedule": "manual",
      "enabled": true
    },
    {
      "id": "qa-risk-review",
      "name": "质控风险复核",
      "audience": "物理师",
      "dataset": "qaReports",
      "fields": [
        "patientId",
        "type",
        "score",
        "result",
        "createdAt"
      ],
      "schedule": "daily",
      "enabled": true
    }
  ],
